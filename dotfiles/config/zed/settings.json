{
	"disable_ai": true,
	"project_panel": {
		"dock": "left"
	},
	"outline_panel": {
		"dock": "left"
	},
	"collaboration_panel": {
		"dock": "left"
	},
	"git_panel": {
		"dock": "left"
	},
	"calls": {
		"mute_on_join": true
	},
	"terminal": {
		"dock": "right",
		"font_size": 14.0
	},
	"use_system_window_tabs": false,
	"bottom_dock_layout": "contained",
	"tabs": {
		"file_icons": false,
		"git_status": false
	},
	"title_bar": {
		"show_menus": false
	},
	"colorize_brackets": true,
	"completions": {
		"words_min_length": 3
	},
	"show_whitespaces": "selection",
	"indent_guides": {
		"background_coloring": "disabled",
		"coloring": "indent_aware",
		"line_width": 1
	},
	"allow_rewrap": "in_comments",
	"soft_wrap": "bounded",
	"toolbar": {
		"code_actions": true
	},
	"minimap": {
		"max_width_columns": 100,
		"thumb_border": "left_open",
		"thumb": "always",
		"show": "never"
	},
	"scrollbar": {
		"show": "auto"
	},
	"relative_line_numbers": "disabled",
	"gutter": {
		"line_numbers": true
	},
	"sticky_scroll": {
		"enabled": false
	},
	"rounded_selection": true,
	"current_line_highlight": "all",
	"unnecessary_code_fade": 0.3,
	"ui_font_family": "SF Pro Display",
	"buffer_line_height": "comfortable",
	"buffer_font_weight": 400.0,
	"icon_theme": "Colored Zed Icons Theme Dark",
	"redact_private_values": false,
	"telemetry": {
		"diagnostics": true,
		"metrics": true
	},
	"agent": {
		"dock": "right",
		"profiles": {
			"minimal": {
				"name": "Minimal",
				"tools": {},
				"enable_all_context_servers": false,
				"context_servers": {
					"effect-mcp": {
						"tools": {
							"get_effect_doc": true,
							"effect_doc_search": true
						}
					}
				}
			},
			"ask": {
				"name": "Ask",
				"tools": {
					"search_web": true,
					"contents": true,
					"diagnostics": true,
					"fetch": true,
					"list_directory": true,
					"now": true,
					"find_path": true,
					"read_file": true,
					"open": true,
					"grep": true,
					"thinking": true
				},
				"enable_all_context_servers": false,
				"context_servers": {
					"effect-mcp": {
						"tools": {
							"get_effect_doc": true,
							"effect_doc_search": true
						}
					}
				}
			}
		},
		"default_profile": "ask",
		"model_parameters": [],
		"default_model": {
			"provider": "copilot_chat",
			"model": "gemini-2.5-pro"
		}
	},
	"show_edit_predictions": true,
	"edit_predictions": {
		"provider": "copilot",
		"mode": "subtle",
		"copilot": {
			"enable_next_edit_suggestions": true,
			"proxy": null,
			"proxy_no_verify": null
		}
	},
	"format_on_save": "on",
	"helix_mode": true,
	"tab_size": 2,
	"ui_font_size": 16,
	"buffer_font_family": "Liga SFMono Nerd Font",
	"buffer_font_size": 16.0,
	"theme": {
		"mode": "dark",
		"light": "Gruvbox Light",
		"dark": "One Dark"
	},
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": false
			}
		}
	},
	"languages": {
		"Odin": {
			"preferred_line_length": 100
		},
		"Rust": {
			"tab_size": 2
		},
		"JavaScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TypeScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TSX": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"JSONC": {
			"formatter": { "language_server": { "name": "biome" } }
		},
		"CSS": {
			"formatter": { "language_server": { "name": "biome" } }
		},
		"Svelte": {
			"formatter": { "language_server": { "name": "biome" } },
			"format_on_save": "on"
		},
		"Astro": {
			"formatter": { "language_server": { "name": "biome" } }
		}
	}
}
