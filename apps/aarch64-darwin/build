#!/bin/sh -e

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

# Resolve the config label by matching $(whoami) against the `machines` map in
# config.nix (single source of truth). Override with MACHINE=<label>.
if [ -z "$MACHINE" ]; then
  ME="$(whoami)"
  MACHINE="$(nix --extra-experimental-features 'nix-command flakes' eval --raw .#machines \
    --apply 'ms: let m = builtins.filter (n: ms.${n} == "'"$ME"'") (builtins.attrNames ms); in if m == [] then "" else builtins.head m' 2>/dev/null)"
fi
if [ -z "$MACHINE" ]; then
  echo "${RED}No machine in config.nix matches user '$(whoami)'. Set MACHINE=<label> or add an entry to config.nix.${NC}"
  exit 1
fi
FLAKE_SYSTEM="darwinConfigurations.${MACHINE}.system"

export NIXPKGS_ALLOW_UNFREE=1

echo "${YELLOW}Starting build for '${MACHINE}'...${NC}"
nix --extra-experimental-features 'nix-command flakes' build .#$FLAKE_SYSTEM $@

echo "${YELLOW}Cleaning up...${NC}"
unlink ./result

echo "${GREEN}Build complete!${NC}"
