#!/bin/sh -e

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

# Parse --no-secrets (build the agenix-free config variant) out of the args
# so it isn't forwarded to nix/darwin-rebuild.
SUFFIX=""
ARGS=""
for a in "$@"; do
  case "$a" in
    --no-secrets) SUFFIX="-no-secrets" ;;
    *) ARGS="$ARGS $a" ;;
  esac
done
set -- $ARGS

# Resolve the config label by matching $(whoami) against the `machines` map in
# flake.nix (single source of truth). Override with MACHINE=<label>.
if [ -z "$MACHINE" ]; then
  ME="$(whoami)"
  MACHINE="$(nix --extra-experimental-features 'nix-command flakes' eval --raw .#machines \
    --apply 'ms: let m = builtins.filter (n: ms.${n}.user == "'"$ME"'") (builtins.attrNames ms); in if m == [] then "" else builtins.head m' 2>/dev/null)"
fi
if [ -z "$MACHINE" ]; then
  echo "${RED}No machine in flake.nix matches user '$(whoami)'. Set MACHINE=<label> or add an entry to flake.nix.${NC}"
  exit 1
fi
MACHINE="${MACHINE}${SUFFIX}"
FLAKE_SYSTEM="darwinConfigurations.${MACHINE}.system"

export NIXPKGS_ALLOW_UNFREE=1

echo "${YELLOW}Starting build for '${MACHINE}'...${NC}"
nix --extra-experimental-features 'nix-command flakes' build .#$FLAKE_SYSTEM $@

echo "${YELLOW}Switching to new generation...${NC}"
# See https://github.com/nix-darwin/nix-darwin/issues/1457 on why we need sudo
sudo ./result/sw/bin/darwin-rebuild switch --flake .#${MACHINE} $@

echo "${YELLOW}Cleaning up...${NC}"
unlink ./result

echo "${GREEN}Switch to new generation complete!${NC}"
